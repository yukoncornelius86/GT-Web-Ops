# Copy to .env on the Synology deployment folder and replace all secrets.

# General
PROJECT_NAME=gt-web-ops
TZ=America/New_York

# Synology review binding
# Keep 127.0.0.1 for SSH tunnel-only access.
# Set to your NAS LAN IP, for example 192.168.1.50, to review from another device on your LAN.
SYNOLOGY_BIND_IP=127.0.0.1

# n8n
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_ENCRYPTION_KEY=replace-with-a-long-random-string
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false
WEBHOOK_URL=http://localhost:5678/
AUTOMATION_PUBLIC_URL=https://automation.thegtcollective.com

# Postgres
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change-me

# Blog Studio
BLOG_STUDIO_PORT=8787
BLOG_STUDIO_SECRET_KEY=change-me
BLOG_STUDIO_DEFAULT_SITE=thegtcafe
BLOG_STUDIO_REPO_PATH=/workspace
BLOG_STUDIO_DEFAULT_AUTHOR=Mike Zanni

# Static/Caddy local preview
STATIC_PREVIEW_PORT=8080
CADDY_LOCAL_PORT=8088

# Optional tools profile
PORTAINER_PORT=9000
UPTIME_KUMA_PORT=3001

# Google Workspace placeholders
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_SHEET_ID=
GOOGLE_CALENDAR_ID=
GOOGLE_DRIVE_LEADS_FOLDER_ID=
GOOGLE_WORKSPACE_SENDER=crew@thegtcafe.com
GOOGLE_WORKSPACE_NOTIFY_TO=crew@thegtcafe.com

# SMTP optional placeholders
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=crew@thegtcafe.com

# Square placeholders for future
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=

# GitHub placeholders
GITHUB_REMOTE=origin
GITHUB_BRANCH=main

# IONOS deployment placeholders
IONOS_SFTP_HOST=
IONOS_SFTP_PORT=22
IONOS_SFTP_USER=
IONOS_SFTP_PASSWORD=
IONOS_THEGTCAFE_TARGET_PATH=
IONOS_THEGTCOLLECTIVE_TARGET_PATH=
